use OO::Monitors;

use Test;

my $debug = 1;

use MacOS::NativeLib "*";
use PDF::Font::Loader::HarfBuzz;
use PDF::Font::Loader :load-font;
use PDF::Content;
use PDF::Content::FontObj;
use PDF::Lite;

use NotoFonts-OT;
use NotoFonts-OT::FontPaths;

my $ff = NotoFonts-OT.new;

isa-ok $ff, NotoFonts-OT;

if $debug {
    say "WARNING: This test MUST pass in order to publish";
#   exit;
}

my %fonts = get-font-file-paths-hash;
my $last-font;
my @codes = 't', 'se', 1;
for @codes.kv -> $i, $code {
#   my $f = $ff.get-font: $fnam;
    my $fnam = %fonts{$code};
    my $f = load-font :file($fnam);
    isa-ok $f, PDF::Content::FontObj;

    =begin comment
    if $i {
        is $f, $last-font;
    }
    =end comment

    # save for the next comparison
    $last-font = $f;
}

done-testing;
=finish

# check ALL fonts load;
#for $ff.codes-list.sort -> $code {
for %fonts.keys -> $code {
    #my $f = $ff.get-font: $code;
    my $f = load-font :file($code);
    say $f.font-name;
}

